{
  "name": "orion-browser",
  "version": "1.0.0",
  "description": "Privacy-focused browser with AI sidebar",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.orion.browser",
    "productName": "Orion Browser",
    "asar": true,
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
  "src/**/*",
  "package.json",
  "!**/*.map",
  "!**/tests",
  "!**/.git"
]
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}
